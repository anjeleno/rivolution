# Targeted sudoers rule for the rivapi dashboard process (runs as rd).
# Grants NOPASSWD access to start/stop/restart exactly the managed stack
# units. Read-only commands (is-active, status) do not require privilege
# and are called directly without sudo.

Cmnd_Alias RIVAPI_SYSTEMCTL = \
    /usr/bin/systemctl start rivolution-stack.target, \
    /usr/bin/systemctl stop rivolution-stack.target, \
    /usr/bin/systemctl restart rivolution-stack.target, \
    /usr/bin/systemctl start rivendell.service, \
    /usr/bin/systemctl stop rivendell.service, \
    /usr/bin/systemctl restart rivendell.service, \
    /usr/bin/systemctl start icecast2.service, \
    /usr/bin/systemctl stop icecast2.service, \
    /usr/bin/systemctl restart icecast2.service, \
    /usr/bin/systemctl start stereo-tool.service, \
    /usr/bin/systemctl stop stereo-tool.service, \
    /usr/bin/systemctl restart stereo-tool.service, \
    /usr/bin/systemctl start tailscaled.service, \
    /usr/bin/systemctl stop tailscaled.service, \
    /usr/bin/systemctl restart tailscaled.service, \
    /usr/bin/systemctl start pipewire-system.service, \
    /usr/bin/systemctl stop pipewire-system.service, \
    /usr/bin/systemctl restart pipewire-system.service, \
    /usr/bin/systemctl start wireplumber-system.service, \
    /usr/bin/systemctl stop wireplumber-system.service, \
    /usr/bin/systemctl restart wireplumber-system.service, \
    /usr/bin/systemctl restart rivapi.service, \
    /usr/bin/systemctl enable --now mariadb.service, \
    /usr/bin/systemctl restart mariadb.service, \
    /usr/bin/systemctl restart autofs.service, \
    /usr/bin/systemctl daemon-reload

Cmnd_Alias RIVAPI_INSTALL = \
    /usr/bin/install -o root -g icecast -m 640 /home/rd/etc/icecast/icecast.xml /etc/icecast2/icecast.xml, \
    /usr/bin/install -m 755 /home/rd/dev/rivolution/rivapi/rivapi /usr/bin/rivapi

# Mode page (standalone/server/client switching). Every command below is a
# fixed, fully-spelled-out argument list with no shell involved (rivapi
# calls exec.Command directly, never a shell string) and, as of 2026-07-04,
# no wildcards at all -- Ubuntu 26.04's sudo-rs (Ubuntu's Rust
# reimplementation of sudo) rejects wildcards in command arguments outright
# ("wildcards are not allowed in command arguments"), unlike traditional GNU
# sudo. The one place operator-entered text (the remote NFS host) needs to
# reach a privileged command is RIVAPI_CONTROL_SCRIPTS' mount-var-snd.sh
# below -- whitelisted by bare path (any arguments), with the actual
# validation moved inside the script itself.
Cmnd_Alias RIVAPI_MODE_APT = \
    /usr/bin/apt-get install -y mariadb-server mariadb-client, \
    /usr/bin/apt-get install -y nfs-kernel-server, \
    /usr/bin/apt-get install -y nfs-common autofs

Cmnd_Alias RIVAPI_MODE_NFS_SERVER = \
    /usr/bin/mkdir -p /srv/nfs4/var/snd, \
    /usr/bin/mkdir -p /srv/nfs4/home/rd/music_export, \
    /usr/bin/mkdir -p /srv/nfs4/home/rd/music_import, \
    /usr/bin/mkdir -p /srv/nfs4/home/rd/traffic_export, \
    /usr/bin/mkdir -p /srv/nfs4/home/rd/traffic_import, \
    /usr/bin/mkdir -p /srv/nfs4/home/rd/rd_xfer, \
    /usr/bin/mount --bind /var/snd /srv/nfs4/var/snd, \
    /usr/bin/mount --bind /home/rd/music_export /srv/nfs4/home/rd/music_export, \
    /usr/bin/mount --bind /home/rd/music_import /srv/nfs4/home/rd/music_import, \
    /usr/bin/mount --bind /home/rd/traffic_export /srv/nfs4/home/rd/traffic_export, \
    /usr/bin/mount --bind /home/rd/traffic_import /srv/nfs4/home/rd/traffic_import, \
    /usr/bin/mount --bind /home/rd/rd_xfer /srv/nfs4/home/rd/rd_xfer, \
    /usr/sbin/exportfs -ra

Cmnd_Alias RIVAPI_MODE_NFS_CLIENT = \
    /usr/bin/umount /var/snd

Cmnd_Alias RIVAPI_MODE_INSTALL = \
    /usr/bin/install -o root -g root -m 644 /home/rd/etc/rivolution/staging/rd.conf.staged /etc/rivendell.d/rd-default.conf, \
    /usr/bin/install -o root -g root -m 644 /home/rd/etc/rivolution/staging/50-server.cnf.staged /etc/mysql/mariadb.conf.d/50-server.cnf, \
    /usr/bin/install -m 644 /home/rd/etc/rivolution/staging/exports.staged /etc/exports, \
    /usr/bin/install -m 644 /home/rd/etc/rivolution/staging/fstab.staged /etc/fstab, \
    /usr/bin/install -m 644 /home/rd/etc/rivolution/staging/auto.rd.audiostore.staged /etc/auto.rd.audiostore, \
    /usr/bin/install -m 644 /home/rd/etc/rivolution/staging/auto.master.staged /etc/auto.master

# Scheduled Tasks page. Task IDs are always server-generated 16-character
# hex strings (store/tasks.go's NewTaskID/validTaskID), never taken
# directly from operator-entered text -- but since they still vary per
# task, the destination unit filename can't be a fixed sudoers argument
# (and, as of 2026-07-04, sudo-rs won't accept a wildcard one either -- see
# RIVAPI_MODE_APT's comment above). RIVAPI_CONTROL_SCRIPTS below whitelists
# each control script by bare path only (no arguments specified, which
# grants running it with any arguments) -- each script re-validates the
# task ID shape itself in shell before touching any file, so the
# specificity sudoers itself can no longer express lives in the script.
Cmnd_Alias RIVAPI_TASK_HELPERS = \
    /usr/bin/mkdir -p /usr/lib/rivolution/scheduled-tasks, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/helper-db_backup.sh /usr/lib/rivolution/scheduled-tasks/db-backup.sh, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/helper-log_gen.sh /usr/lib/rivolution/scheduled-tasks/log-gen.sh, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/helper-log_reconcile.sh /usr/lib/rivolution/scheduled-tasks/log-reconcile.sh

Cmnd_Alias RIVAPI_CONTROL_SCRIPT_DEPLOY = \
    /usr/bin/mkdir -p /usr/lib/rivolution/control-scripts, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/control-install-unit.sh /usr/lib/rivolution/control-scripts/install-unit.sh, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/control-remove-unit.sh /usr/lib/rivolution/control-scripts/remove-unit.sh, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/control-task-systemctl.sh /usr/lib/rivolution/control-scripts/task-systemctl.sh, \
    /usr/bin/install -m 755 /home/rd/etc/rivolution/staging/control-mount-var-snd.sh /usr/lib/rivolution/control-scripts/mount-var-snd.sh

Cmnd_Alias RIVAPI_CONTROL_SCRIPTS = \
    /usr/lib/rivolution/control-scripts/install-unit.sh, \
    /usr/lib/rivolution/control-scripts/remove-unit.sh, \
    /usr/lib/rivolution/control-scripts/task-systemctl.sh, \
    /usr/lib/rivolution/control-scripts/mount-var-snd.sh

rd ALL=(root) NOPASSWD: RIVAPI_SYSTEMCTL, RIVAPI_INSTALL, RIVAPI_MODE_APT, RIVAPI_MODE_NFS_SERVER, RIVAPI_MODE_NFS_CLIENT, RIVAPI_MODE_INSTALL, RIVAPI_TASK_HELPERS, RIVAPI_CONTROL_SCRIPT_DEPLOY, RIVAPI_CONTROL_SCRIPTS
